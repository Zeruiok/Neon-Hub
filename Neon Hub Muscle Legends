local function _initstats()
    local plr=game.Players.LocalPlayer if not plr then return end
    local ls=plr:WaitForChild("leaderstats") if not ls then return end
    local str=ls:WaitForChild("Strength")
    local dur=plr:WaitForChild("Durability")
    local agi=plr:WaitForChild("Agility")
    local kls=ls:WaitForChild("Kills")
    local evk=plr:WaitForChild("evilKarma")
    local gdk=plr:WaitForChild("goodKarma")
    
    local istr,idur,iagi,ikls,ievk,igdk=str.Value or 0,dur.Value or 0,agi.Value or 0,kls.Value or 0,evk.Value or 0,gdk.Value or 0
    local start=tick()
    
    local function upd()
        local sg,dg,ag,kg,eg,gg=str.Value-istr,dur.Value-idur,agi.Value-iagi,kls.Value-ikls,evk.Value-ievk,gdk.Value-igdk
        _labels.StrengthGainedLabel:SetText("Strength: ".._abbr(sg))
        _labels.DurabilityGainedLabel:SetText("Durability: ".._abbr(dg))
        _labels.AgilityGainedLabel:SetText("Agility: ".._abbr(ag))
        _labels.KillsGainedLabel:SetText("Kills: ".._abbr(kg))
        _labels.EvilKarmaGainedLabel:SetText("Evil Karma: ".._abbr(eg))
        _labels.GoodKarmaGainedLabel:SetText("Good Karma: ".._abbr(gg))
    end
    
    local function uptime()
        local t=tick()-start
        local m,s=math.floor(t/60),math.floor(t%60)
        _labels.TimeSpentLabel:SetText(string.format("Time: %02d:%02d",m,s))
    end
    
    str.Changed:Connect(upd) dur.Changed:Connect(upd) agi.Changed:Connect(upd) kls.Changed:Connect(upd) evk.Changed:Connect(upd) gdk.Changed:Connect(upd)
    _rs.Heartbeat:Connect(uptime) upd()
end _initstats()

